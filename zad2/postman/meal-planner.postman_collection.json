{
  "info": {
    "_postman_id": "f2f89ff5-3af2-4ccf-b168-7cbcf49ee001",
    "name": "Meal Planner FastAPI Demo",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Gotowe testy do demo: klient-serwer i serwer-serwis_publiczny"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://127.0.0.1:8000"
    }
  ],
  "item": [
    {
      "name": "1) Healthcheck",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/healthz",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "healthz"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', function () { pm.response.to.have.status(200); });"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "2) API Generate - valid",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"height\": 183,\n  \"weight\": 80,\n  \"age\": 22,\n  \"gender\": \"m\",\n  \"activity\": \"medium\",\n  \"preference\": \"\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/generate",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "generate"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
              "const data = pm.response.json();",
              "pm.test('Has meals array', function () { pm.expect(Array.isArray(data.meals)).to.eql(true); });",
              "pm.test('Has 4 meals', function () { pm.expect(data.meals.length).to.eql(4); });"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "3) API Generate - invalid input",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"height\": 183,\n  \"weight\": 80,\n  \"age\": 22,\n  \"gender\": \"m\",\n  \"activity\": \"super\",\n  \"preference\": \"\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/generate",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "generate"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 422', function () { pm.response.to.have.status(422); });"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "4) External API check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/external-check?query=chicken",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "external-check"
          ],
          "query": [
            {
              "key": "query",
              "value": "chicken"
            }
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200 or 502', function () { pm.expect([200,502]).to.include(pm.response.code); });"
            ],
            "type": "text/javascript"
          }
        }
      ]
    }
  ]
}
